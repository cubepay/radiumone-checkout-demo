# RadiumOne Checkout HPP — sandbox host.
# Sandbox is public; use it as-is to run against the real sandbox API.
# For the PRODUCTION host, ask your RadiumOne contact (it is a different host).
# Test vs production is selected by the secret key prefix below
# (r1sk_test_* = sandbox, r1sk_prod_* = production).
RADIUMONE_BASE_URL=https://checkout-sandbox.radiumone.com

# Secret key — server-side ONLY. NEVER ship to the browser.
# Get from merchant dashboard → API keys.
RADIUMONE_SECRET_KEY=r1sk_test_replace_me

# Public URL this demo is served from. HPP redirects back here on success/cancel.
MERCHANT_BASE_URL=http://localhost:3000

# OPTIONAL — Gateway webhook signing secret (whsec_<hex>), issued by CubePay
# support when you register a webhook endpoint. Only needed to verify deliveries
# at POST /api/webhook (Step 4). Leave unset if you're not testing webhooks.
# RADIUMONE_WEBHOOK_SECRET=whsec_replace_me
